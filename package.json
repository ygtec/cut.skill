{
  "name": "cut-skill-root",
  "version": "1.2.0",
  "description": "Unified video editing control skill for AI agents (JianYing + Premiere). This is the root package; the actual installer is in installer/",
  "type": "module",
  "private": true,
  "bin": {
    "cut-skill": "./installer/cli.mjs"
  },
  "scripts": {
    "install:all": "node installer/cli.mjs install --all --source .",
    "install:claude": "node installer/cli.mjs install --agent claude --source .",
    "list": "node installer/cli.mjs list",
    "detect": "node installer/cli.mjs detect",
    "test": "python tests/run_all.py"
  },
  "keywords": [
    "skill",
    "ai-agent",
    "video-editing",
    "jianying",
    "capcut",
    "premiere",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ygtec/cut.skill.git"
  },
  "homepage": "https://github.com/ygtec/cut.skill#readme",
  "bugs": {
    "url": "https://github.com/ygtec/cut.skill/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
